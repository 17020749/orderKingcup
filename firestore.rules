rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Authentication and user permissions
    // ---------------------------------------------------------------------

    function signedIn() {
      return request.auth != null
        && request.auth.token.email is string;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(email());
    }

    function activeUserData(user) {
      return user.get('deleted', false) != true
        && (
          user.get('active', false) == true
          || user.get('status', '') == 'active'
          || user.get('status', '') == 'Hoạt động'
        );
    }

    function adminUserData(user) {
      return user.get('is_admin', false) == true
        || (
          user.get('permissions_flat', []) is list
          && '*' in user.get('permissions_flat', [])
        )
        || (
          user.get('roles', []) is list
          && (
            'admin' in user.get('roles', [])
            || 'Admin' in user.get('roles', [])
            || 'role_admin' in user.get('roles', [])
          )
        )
        || (
          user.get('role', '') is list
          && (
            'admin' in user.get('role', [])
            || 'Admin' in user.get('role', [])
            || 'role_admin' in user.get('role', [])
          )
        )
        || user.get('role', '') == 'admin'
        || user.get('role', '') == 'Admin'
        || user.get('role', '') == 'role_admin';
    }

    function activeUser() {
      let path = userPath();
      let user = get(path).data;
      return signedIn()
        && exists(path)
        && activeUserData(user);
    }

    // Keep compatibility with the role formats already used by the project.
    function isAdmin() {
      let path = userPath();
      let user = get(path).data;
      return signedIn()
        && exists(path)
        && activeUserData(user)
        && adminUserData(user);
    }

    function hasPerm(permission) {
      let path = userPath();
      let user = get(path).data;
      return signedIn()
        && exists(path)
        && activeUserData(user)
        && (
          adminUserData(user)
          || (
            user.get('permissions_flat', []) is list
            && permission in user.get('permissions_flat', [])
          )
        );
    }

    function hasAnyPerm(permissions) {
      let path = userPath();
      let user = get(path).data;
      return signedIn()
        && exists(path)
        && activeUserData(user)
        && (
          adminUserData(user)
          || (
            user.get('permissions_flat', []) is list
            && user.get('permissions_flat', []).hasAny(permissions)
          )
        );
    }


    function userHasPermData(user, permission) {
      return activeUserData(user)
        && (
          adminUserData(user)
          || (
            user.get('permissions_flat', []) is list
            && permission in user.get('permissions_flat', [])
          )
        );
    }

    function userHasAnyPermData(user, permissions) {
      return activeUserData(user)
        && (
          adminUserData(user)
          || (
            user.get('permissions_flat', []) is list
            && user.get('permissions_flat', []).hasAny(permissions)
          )
        );
    }

    function notificationAudienceMatches(data) {
      return data.get('audience', '') == 'warehouse_export'
        && hasPerm('page.warehouse_export_requests')
        && hasAnyPerm([
          'export_requests.accept',
          'export_requests.reject',
          'export_requests.release',
          'export_requests.process'
        ]);
    }

    function notificationCreateTargetIsValid() {
      let directEmail = request.resource.data.get('to_email', '');
      let audience = request.resource.data.get('audience', '');
      return (
          directEmail is string
          && directEmail != ''
        )
        || (
          audience == 'warehouse_export'
          && hasPerm('orders.warehouse_export')
        );
    }

    // ---------------------------------------------------------------------
    // Generic data helpers
    // ---------------------------------------------------------------------

    function emailFieldEquals(data, fieldName, expectedEmail) {
      return data.get(fieldName, '') is string
        && expectedEmail is string
        && data.get(fieldName, '').lower() == expectedEmail.lower();
    }

    function ownEmailField(data, fieldName) {
      return emailFieldEquals(data, fieldName, email());
    }

    function sameEmailField(leftData, rightData, fieldName) {
      return leftData.get(fieldName, '') is string
        && rightData.get(fieldName, '') is string
        && leftData.get(fieldName, '').lower() == rightData.get(fieldName, '').lower();
    }

    function unchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function onlyChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function softDeleteOnly() {
      return onlyChanged([
        'deleted',
        'active',
        'status',
        'deleted_at',
        'updated_at'
      ]);
    }

    function warehouseSoftDeleteOnly() {
      return onlyChanged([
        'deleted',
        'active',
        'status',
        'deleted_at',
        'deleted_by',
        'deleted_reason',
        'cancelled_at',
        'cancelled_by',
        'cancel_reason',
        'updated_by',
        'operation_id',
        'last_operation_id',
        'revision',
        'updated_at'
      ]);
    }

    function manualExportOrderData(data) {
      return data.get('source_request_id', '') == ''
        && data.get('source', '') != 'kingcup_firestore'
        && !data.get('sync_source', '').matches('^kingcup_firestore:.*');
    }

    function manualExportOrderById(orderId) {
      let path = /databases/$(database)/documents/export_orders/$(orderId);
      return orderId is string
        && exists(path)
        && manualExportOrderData(get(path).data);
    }

    // ---------------------------------------------------------------------
    // Order ownership helpers
    // ---------------------------------------------------------------------

    function ownsOrderData(data) {
      return ownEmailField(data, 'owner_email')
        || ownEmailField(data, 'created_by')
        || ownEmailField(data, 'sale_email');
    }

    function ownsOrderChildData(data) {
      return ownEmailField(data, 'created_by')
        || ownEmailField(data, 'requested_by')
        || ownEmailField(data, 'order_owner_email')
        || ownEmailField(data, 'order_created_by')
        || ownEmailField(data, 'order_sale_email');
    }

    function orderPath(orderId) {
      return /databases/$(database)/documents/orders/$(orderId);
    }

    function orderDataIsActive(order) {
      return order.get('deleted', false) != true;
    }

    function ownsOrderById(orderId) {
      let path = orderPath(orderId);
      let order = get(path).data;
      return orderId is string
        && exists(path)
        && orderDataIsActive(order)
        && ownsOrderData(order);
    }

    function canReadOrderById(orderId) {
      let path = orderPath(orderId);
      let order = get(path).data;
      return orderId is string
        && exists(path)
        && orderDataIsActive(order)
        && (
          hasPerm('orders.view_all')
          || ownsOrderData(order)
        );
    }

    function canMutateOrderById(orderId) {
      let path = orderPath(orderId);
      let order = get(path).data;
      return orderId is string
        && exists(path)
        && orderDataIsActive(order)
        && (
          isAdmin()
          || ownsOrderData(order)
        );
    }

    // Payment/export/shipment/invoice documents duplicate parent ownership
    // using order_* fields for scoped queries. These fields must be copied
    // from owner_email/created_by/sale_email on the real parent order.
    function requestMatchesOrder(orderId) {
      let path = orderPath(orderId);
      let order = get(path).data;
      return orderId is string
        && exists(path)
        && orderDataIsActive(order)
        && emailFieldEquals(
          request.resource.data,
          'order_owner_email',
          order.get('owner_email', '')
        )
        && emailFieldEquals(
          request.resource.data,
          'order_created_by',
          order.get('created_by', '')
        )
        && emailFieldEquals(
          request.resource.data,
          'order_sale_email',
          order.get('sale_email', '')
        );
    }


    function requestMatchesOrderData(order) {
      return emailFieldEquals(
          request.resource.data,
          'order_owner_email',
          order.get('owner_email', '')
        )
        && emailFieldEquals(
          request.resource.data,
          'order_created_by',
          order.get('created_by', '')
        )
        && emailFieldEquals(
          request.resource.data,
          'order_sale_email',
          order.get('sale_email', '')
        );
    }

    // Order items use the original owner_email/created_by/sale_email names.
    function requestMatchesOrderItem(orderId) {
      let path = orderPath(orderId);
      let order = get(path).data;
      return orderId is string
        && exists(path)
        && orderDataIsActive(order)
        && sameEmailField(request.resource.data, order, 'owner_email')
        && sameEmailField(request.resource.data, order, 'created_by')
        && sameEmailField(request.resource.data, order, 'sale_email');
    }

    // Existing legacy child documents may not have every duplicated field yet.
    // An update may keep them unchanged, or replace all of them with values
    // copied from the real parent order. They can never be client-invented.
    function childOwnershipSafe(orderId) {
      return unchanged([
          'order_owner_email',
          'order_created_by',
          'order_sale_email'
        ])
        || requestMatchesOrder(orderId);
    }

    function orderItemOwnershipSafe(orderId) {
      return unchanged([
          'owner_email',
          'created_by',
          'sale_email'
        ])
        || requestMatchesOrderItem(orderId);
    }

    function orderIdentityUnchanged() {
      return unchanged([
        'owner_email',
        'created_by',
        'sale_email',
        'created_at'
      ]);
    }

    function childIdentityUnchanged() {
      return unchanged([
        'order_id',
        'created_by',
        'created_at'
      ]);
    }

    function fulfillmentStatus() {
      return resource.data.get('warehouse_fulfillment_status', 'chua_xuat');
    }

    function orderCanBeDeleted() {
      return fulfillmentStatus() != 'da_xuat_1_phan'
        && fulfillmentStatus() != 'da_xuat_du';
    }

    function exportRequestEditable() {
      return resource.data.get('status', '') in ['cho_xu_ly', 'dang_xu_ly', 'pending'];
    }

    function exportRequestCanBeDeleted() {
      return resource.data.get('status', '') in ['cho_xu_ly', 'dang_xu_ly', 'pending']
        && resource.data.get('warehouse_export_code', '') == '';
    }

    function onlyPaymentSummaryChanged() {
      return onlyChanged([
        'paid_amount',
        'debt_amount',
        'computed_payment_status',
        'payment_status',
        'payment_count',
        'deposit_count',
        'collect_count',
        'updated_at'
      ]);
    }

    function onlyWarehouseSummaryChanged() {
      return onlyChanged([
        'warehouse_fulfillment_status',
        'warehouse_request_status',
        'updated_at'
      ]);
    }


    // ---------------------------------------------------------------------
    // Warehouse Core helpers
    // ---------------------------------------------------------------------

    function canReadWarehouseCatalog() {
      return hasAnyPerm([
        'warehouses.view',
        'warehouses.manage',
        'suppliers.view',
        'suppliers.manage',
        'units.view',
        'units.manage',
        'import.view',
        'export.view',
        'inventory.view',
        'page.warehouse_export_requests',
        'export_requests.accept',
        'export_requests.reject',
        'export_requests.release',
        'export_requests.process'
      ]);
    }

    function canWriteWarehouseCatalog() {
      return hasAnyPerm([
        'warehouses.manage',
        'suppliers.manage',
        'units.manage'
      ]);
    }

    function canReadInventoryCore() {
      return hasAnyPerm([
        'inventory.view',
        'import.view',
        'export.view',
        'stock_movements.view',
        'export_requests.release',
        'export_requests.process'
      ]);
    }

    function canWriteInventoryCore() {
      let path = userPath();
      let user = get(path).data;
      let permissions = user.get('permissions_flat', []);
      return signedIn()
        && exists(path)
        && activeUserData(user)
        && (
          user.get('is_admin', false) == true
          || (
            permissions is list
            && (
              '*' in permissions
              || permissions.hasAny([
                'import.create',
                'import.edit',
                'import.delete',
                'export.create',
                'export.edit',
                'export.delete',
                'inventory.adjust',
                'export_requests.release',
                'export_requests.process'
              ])
            )
          )
        );
    }


    function quantityIsNumber(data) {
      return data.get('quantity', 0) is int
        || data.get('quantity', 0) is float;
    }

    function printQuantitiesAreValid(data) {
      return (
          data.get('print_quantity', 0) is int
          || data.get('print_quantity', 0) is float
        )
        && data.get('print_quantity', 0) > 0
        && (
          data.get('actual_print_quantity', 0) is int
          || data.get('actual_print_quantity', 0) is float
        )
        && data.get('actual_print_quantity', 0) >= 0;
    }

    function balanceQuantityIsSafe() {
      return quantityIsNumber(request.resource.data)
        && request.resource.data.get('quantity', 0) >= 0;
    }

    function warehouseDocIdentitySafe() {
      return unchanged([
        'id',
        'legacy_id',
        'created_at',
        'created_by',
        'source'
      ]);
    }

    function onlyInvoiceStatusChanged() {
      return onlyChanged([
        'invoice_status',
        'updated_at'
      ]);
    }

    // A normal order edit must not directly forge payment, warehouse,
    // invoice or deletion state. Those fields are handled by dedicated rules.
    function normalOrderEditKeepsSystemFields() {
      return unchanged([
          'paid_amount',
          'debt_amount',
          'computed_payment_status',
          'payment_status',
          'payment_count',
          'deposit_count',
          'collect_count',
          'warehouse_fulfillment_status',
          'warehouse_request_status',
          'deleted',
          'active',
          'status',
          'deleted_at'
        ])
        && (
          unchanged(['invoice_status'])
          || hasAnyPerm(['invoices.create', 'invoices.edit', 'invoices.delete'])
        );
    }


    function orderWarehouseSummaryUpdateAllowed() {
      return onlyWarehouseSummaryChanged()
        && (
          (
            hasPerm('orders.warehouse_export')
            && ownsOrderData(resource.data)
          )
          || hasAnyPerm([
            'export_requests.accept',
            'export_requests.reject',
            'export_requests.release',
            'export_requests.process'
          ])
        );
    }

    function exportCreateAllowed() {
      let userPathValue = userPath();
      let user = get(userPathValue).data;
      let path = orderPath(request.resource.data.order_id);
      let order = get(path).data;
      return signedIn()
        && request.resource.data.order_id is string
        && exists(userPathValue)
        && exists(path)
        && userHasPermData(user, 'orders.warehouse_export')
        && orderDataIsActive(order)
        && (
          adminUserData(user)
          || ownsOrderData(order)
        )
        && requestMatchesOrderData(order)
        && ownEmailField(request.resource.data, 'requested_by');
    }

    function exportSoftDeleteAllowed() {
      return exportRequestCanBeDeleted()
        && softDeleteOnly()
        && hasAnyPerm(['export_requests.delete', 'orders.delete'])
        && ownsOrderChildData(resource.data);
    }

    function exportOwnerEditAllowed() {
      return exportRequestEditable()
        && onlyChanged([
          'order_code',
          'customer_name',
          'export_date',
          'updated_by',
          'payload_json',
          'request_timeline_json',
          'updated_at'
        ])
        && hasPerm('orders.warehouse_export')
        && ownsOrderChildData(resource.data)
        && ownEmailField(request.resource.data, 'updated_by');
    }


    function exportWarehouseProcessAllowed() {
      let path = userPath();
      let user = get(path).data;
      let permissions = user.get('permissions_flat', []);
      let admin = adminUserData(user);
      let legacyProcess = admin
        || (
          permissions is list
          && 'export_requests.process' in permissions
        );
      return signedIn()
        && exists(path)
        && activeUserData(user)
        && onlyChanged([
          'status',
          'warehouse_export_code',
          'warehouse_handled_by',
          'warehouse_handled_at',
          'warehouse_note',
          'warehouse_export_id',
          'warehouse_export_order_id',
          'export_order_id',
          'exported_at',
          'actual_exported_at',
          'actual_export_summary_json',
          'stock_movement_ids',
          'request_timeline_json',
          'operation_id',
          'last_operation_id',
          'revision',
          'updated_at'
        ])
        && ownEmailField(request.resource.data, 'warehouse_handled_by')
        && (
          legacyProcess
          || (
            permissions is list
            && 'export_requests.accept' in permissions
            && resource.data.get('status', '') in ['cho_xu_ly', 'pending']
            && request.resource.data.get('status', '') in ['da_tiep_nhan', 'cho_xuat_kho']
          )
          || (
            permissions is list
            && 'export_requests.reject' in permissions
            && !(resource.data.get('status', '') in ['tu_choi', 'da_xuat'])
            && request.resource.data.get('status', '') == 'tu_choi'
          )
          || (
            permissions is list
            && 'export_requests.release' in permissions
            && resource.data.get('status', '') in ['cho_xu_ly', 'pending', 'dang_xu_ly', 'da_tiep_nhan', 'cho_xuat_kho']
            && request.resource.data.get('status', '') == 'da_xuat'
          )
        );
    }

    // ---------------------------------------------------------------------
    // Users, roles and settings
    // ---------------------------------------------------------------------

    match /users/{userId} {
      // A signed-in account can read only its own profile, even when inactive,
      // so the UI can show the correct disabled-account message.
      allow get: if signedIn() && userId == email();

      // Only an absolute admin may enumerate or modify identities and grants.
      // A users.manage permission alone can no longer self-escalate to '*'.
      allow list, create, update, delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if hasPerm('settings.view') || hasPerm('settings.manage');
      allow create, update, delete: if hasPerm('settings.manage');
    }

    // ---------------------------------------------------------------------
    // Customers and products
    // ---------------------------------------------------------------------

    match /customers/{docId} {
      allow read: if isAdmin()
        || (
          hasPerm('customers.view')
          && ownEmailField(resource.data, 'created_by')
        );

      allow create: if isAdmin()
        || (
          hasPerm('customers.create')
          && ownEmailField(request.resource.data, 'created_by')
        );

      allow update: if isAdmin()
        || (
          ownEmailField(resource.data, 'created_by')
          && unchanged(['created_by', 'created_at'])
          && (
            (
              hasPerm('customers.edit')
              && unchanged(['deleted', 'active', 'status', 'deleted_at'])
            )
            || (
              hasPerm('customers.delete')
              && softDeleteOnly()
            )
          )
        );

            // Customers are always removed through soft-delete updates.
      allow delete: if false;

    }

    match /products/{docId} {
      allow read: if hasAnyPerm(['products.view', 'inventory.view', 'printing.view']);

      allow create: if isAdmin()
        || (
          hasPerm('products.create')
          && ownEmailField(request.resource.data, 'created_by')
        );

      allow update: if isAdmin()
        || (
          hasPerm('products.edit')
          && unchanged(['created_at', 'deleted', 'deleted_at'])
          && (
            unchanged(['created_by'])
            || (
              resource.data.get('created_by', '') == ''
              && ownEmailField(request.resource.data, 'created_by')
            )
          )
        )
        || (
          hasPerm('products.delete')
          && softDeleteOnly()
        );

      // Products are always removed through soft-delete updates so old order
      // and inventory history keeps its original product reference.
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Orders
    // ---------------------------------------------------------------------

    match /orders/{docId} {
      allow read: if hasPerm('orders.view_all')
        || (
          hasPerm('orders.view')
          && ownsOrderData(resource.data)
        );

      allow create: if hasPerm('orders.create')
        && ownEmailField(request.resource.data, 'created_by')
        && ownsOrderData(request.resource.data);

      allow update: if orderWarehouseSummaryUpdateAllowed()
        || isAdmin()
        || (
          // Normal business edit by an owner.
          hasPerm('orders.edit')
          && ownsOrderData(resource.data)
          && orderIdentityUnchanged()
          && normalOrderEditKeepsSystemFields()
          && (
            fulfillmentStatus() != 'da_xuat_du'
            || hasPerm('orders.edit_fulfilled')
          )
        )
        || (
          // Payment module updates only computed payment fields.
          hasAnyPerm(['payments.create', 'payments.edit', 'payments.delete'])
          && ownsOrderData(resource.data)
          && orderIdentityUnchanged()
          && onlyPaymentSummaryChanged()
        )
        || (
          // Owner soft-delete before any warehouse fulfillment.
          hasPerm('orders.delete')
          && ownsOrderData(resource.data)
          && orderIdentityUnchanged()
          && orderCanBeDeleted()
          && softDeleteOnly()
        )
        || (
          // Invoice module updates only invoice status.
          hasAnyPerm(['invoices.create', 'invoices.edit', 'invoices.delete'])
          && ownsOrderData(resource.data)
          && orderIdentityUnchanged()
          && onlyInvoiceStatusChanged()
        );

      allow delete: if isAdmin()
        || (
          hasPerm('orders.delete')
          && ownsOrderData(resource.data)
          && orderCanBeDeleted()
        );
    }

    // ---------------------------------------------------------------------
    // Order items
    // ---------------------------------------------------------------------

    match /order_items/{docId} {
      allow read: if hasPerm('orders.view_all')
        || (
          hasPerm('orders.view')
          && (
            ownsOrderData(resource.data)
            || (
              resource.data.order_id is string
              && canReadOrderById(resource.data.order_id)
            )
          )
        );

      allow create: if hasPerm('orders.create')
        && request.resource.data.order_id is string
        && canMutateOrderById(request.resource.data.order_id)
        && requestMatchesOrderItem(request.resource.data.order_id);

      allow update: if isAdmin()
        || (
          resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
          && request.resource.data.order_id == resource.data.order_id
          && childIdentityUnchanged()
          && orderItemOwnershipSafe(resource.data.order_id)
          && (
            (
              hasPerm('orders.edit')
              && unchanged(['deleted', 'active', 'status', 'deleted_at'])
            )
            || (
              hasPerm('orders.delete')
              && softDeleteOnly()
            )
          )
        );

      allow delete: if isAdmin()
        || (
          hasPerm('orders.delete')
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
        );
    }

    // ---------------------------------------------------------------------
    // Payments
    // ---------------------------------------------------------------------

    match /payments/{docId} {
      allow read: if hasPerm('payments.view_all')
        || (
          hasPerm('payments.view')
          && (
            ownsOrderChildData(resource.data)
            || (
              resource.data.order_id is string
              && ownsOrderById(resource.data.order_id)
            )
          )
        );

      allow create: if hasPerm('payments.create')
        && request.resource.data.order_id is string
        && canMutateOrderById(request.resource.data.order_id)
        && requestMatchesOrder(request.resource.data.order_id)
        && ownEmailField(request.resource.data, 'created_by');

      allow update: if isAdmin()
        || (
          resource.data.order_id is string
          && (
            ownEmailField(resource.data, 'created_by')
            || ownsOrderById(resource.data.order_id)
          )
          && request.resource.data.order_id == resource.data.order_id
          && childIdentityUnchanged()
          && childOwnershipSafe(resource.data.order_id)
          && (
            (
              hasPerm('payments.edit')
              && unchanged(['deleted', 'active', 'status', 'deleted_at'])
            )
            || (
              hasPerm('payments.delete')
              && softDeleteOnly()
            )
          )
        );

      allow delete: if isAdmin()
        || (
          hasPerm('payments.delete')
          && resource.data.order_id is string
          && (
            ownEmailField(resource.data, 'created_by')
            || ownsOrderById(resource.data.order_id)
          )
        );
    }

    // ---------------------------------------------------------------------
    // Warehouse export requests
    // ---------------------------------------------------------------------

    match /order_export_requests/{docId} {
      allow read: if hasAnyPerm([
          'page.warehouse_export_requests',
          'export_requests.accept',
          'export_requests.reject',
          'export_requests.release',
          'export_requests.process'
        ])
        || hasPerm('export_requests.view_all')
        || (
          hasAnyPerm(['export_requests.view', 'orders.warehouse_export'])
          && (
            ownsOrderChildData(resource.data)
            || (
              resource.data.order_id is string
              && ownsOrderById(resource.data.order_id)
            )
          )
        );

      allow create: if exportCreateAllowed();

      // Evaluate cheap operation-shape checks first. This avoids exhausting
      // Firestore's 1000-expression limit on the page's three-write batch.
      allow update: if exportOwnerEditAllowed()
        || exportSoftDeleteAllowed()
        || exportWarehouseProcessAllowed()
        || isAdmin();

      allow delete: if isAdmin()
        || (
          hasAnyPerm(['export_requests.delete', 'orders.delete'])
          && exportRequestCanBeDeleted()
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
        );
    }

    // ---------------------------------------------------------------------
    // Shipments and invoices
    // ---------------------------------------------------------------------

    match /print_orders/{docId} {
      allow read: if hasPerm('printing.view');

      allow create: if hasPerm('printing.create')
        && request.resource.data.get('order_code', '') is string
        && request.resource.data.get('order_code', '') != ''
        && ownEmailField(request.resource.data, 'created_by');

      allow update: if isAdmin()
        || (
          hasPerm('printing.edit')
          && warehouseDocIdentitySafe()
          && request.resource.data.get('order_code', '') is string
          && request.resource.data.get('order_code', '') != ''
          && unchanged(['deleted', 'active', 'status', 'deleted_at', 'deleted_by'])
        )
        || (
          hasPerm('printing.delete')
          && warehouseDocIdentitySafe()
          && warehouseSoftDeleteOnly()
        );

      allow delete: if isAdmin();
    }

    match /print_order_items/{docId} {
      allow read: if hasPerm('printing.view');

      allow create: if hasAnyPerm(['printing.create', 'printing.edit'])
        && request.resource.data.print_order_id is string
        && request.resource.data.get('product_id', '') is string
        && request.resource.data.get('product_id', '') != ''
        && printQuantitiesAreValid(request.resource.data)
        && ownEmailField(request.resource.data, 'created_by');

      allow update: if isAdmin()
        || (
          hasPerm('printing.edit')
          && unchanged(['id', 'print_order_id', 'created_at', 'created_by', 'source'])
          && printQuantitiesAreValid(request.resource.data)
        )
        || (
          hasAnyPerm(['printing.edit', 'printing.delete'])
          && unchanged(['id', 'print_order_id', 'created_at', 'created_by', 'source'])
          && warehouseSoftDeleteOnly()
        );

      allow delete: if isAdmin();
    }

    match /shipments/{docId} {
      allow read: if isAdmin()
        || (
          hasPerm('shipments.view')
          && (
            ownsOrderChildData(resource.data)
            || (
              resource.data.order_id is string
              && ownsOrderById(resource.data.order_id)
            )
          )
        );

      allow create: if hasPerm('shipments.create')
        && request.resource.data.order_id is string
        && canMutateOrderById(request.resource.data.order_id)
        && requestMatchesOrder(request.resource.data.order_id)
        && ownEmailField(request.resource.data, 'created_by');

      allow update: if isAdmin()
        || (
          hasPerm('shipments.edit')
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
          && request.resource.data.order_id == resource.data.order_id
          && childIdentityUnchanged()
          && childOwnershipSafe(resource.data.order_id)
          && unchanged(['deleted', 'active', 'status', 'deleted_at'])
        )
        || (
          hasPerm('shipments.delete')
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
          && childIdentityUnchanged()
          && childOwnershipSafe(resource.data.order_id)
          && softDeleteOnly()
        );

      allow delete: if isAdmin()
        || (
          hasPerm('shipments.delete')
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
        );
    }

    match /invoices/{docId} {
      allow read: if isAdmin()
        || (
          hasPerm('invoices.view')
          && (
            ownsOrderChildData(resource.data)
            || (
              resource.data.order_id is string
              && ownsOrderById(resource.data.order_id)
            )
          )
        );

      allow create: if hasPerm('invoices.create')
        && request.resource.data.order_id is string
        && canMutateOrderById(request.resource.data.order_id)
        && requestMatchesOrder(request.resource.data.order_id)
        && ownEmailField(request.resource.data, 'created_by');

      allow update: if isAdmin()
        || (
          hasPerm('invoices.edit')
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
          && request.resource.data.order_id == resource.data.order_id
          && childIdentityUnchanged()
          && childOwnershipSafe(resource.data.order_id)
          && unchanged(['deleted', 'active', 'status', 'deleted_at'])
        )
        || (
          hasPerm('invoices.delete')
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
          && childIdentityUnchanged()
          && childOwnershipSafe(resource.data.order_id)
          && softDeleteOnly()
        );

      allow delete: if isAdmin()
        || (
          hasPerm('invoices.delete')
          && resource.data.order_id is string
          && canMutateOrderById(resource.data.order_id)
        );
    }

    // ---------------------------------------------------------------------
    // Warehouse Core: catalogs, real stock documents and balances
    // ---------------------------------------------------------------------

    match /warehouses/{docId} {
      allow read: if canReadWarehouseCatalog();
      allow create: if hasAnyPerm(['warehouses.manage'])
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if hasAnyPerm(['warehouses.manage'])
        && warehouseDocIdentitySafe();
      allow delete: if isAdmin();
    }

    match /suppliers/{docId} {
      allow read: if canReadWarehouseCatalog()
        || hasPerm('printing.view');
      allow create: if hasAnyPerm(['suppliers.manage'])
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if hasAnyPerm(['suppliers.manage'])
        && warehouseDocIdentitySafe();
      allow delete: if isAdmin();
    }

    match /units/{docId} {
      allow read: if canReadWarehouseCatalog();
      allow create: if hasAnyPerm(['units.manage'])
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if hasAnyPerm(['units.manage'])
        && warehouseDocIdentitySafe();
      allow delete: if isAdmin();
    }

    match /import_orders/{docId} {
      allow read: if hasAnyPerm(['import.view']);
      allow create: if hasAnyPerm(['import.create'])
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if isAdmin()
        || (
          hasAnyPerm(['import.edit'])
          && warehouseDocIdentitySafe()
          && unchanged(['deleted', 'active', 'status', 'deleted_at'])
        )
        || (
          hasAnyPerm(['import.delete'])
          && warehouseDocIdentitySafe()
          && warehouseSoftDeleteOnly()
        );
      allow delete: if isAdmin();
    }

    match /import_order_items/{docId} {
      allow read: if hasAnyPerm(['import.view']);
      allow create: if hasAnyPerm(['import.create', 'import.edit'])
        && request.resource.data.import_order_id is string
        && quantityIsNumber(request.resource.data)
        && request.resource.data.get('quantity', 0) > 0
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if isAdmin()
        || (
          hasAnyPerm(['import.edit'])
          && unchanged(['import_order_id', 'created_at', 'created_by', 'source'])
          && quantityIsNumber(request.resource.data)
          && request.resource.data.get('quantity', 0) > 0
        )
        || (
          hasAnyPerm(['import.delete'])
          && unchanged(['import_order_id', 'created_at', 'created_by', 'source'])
          && warehouseSoftDeleteOnly()
        );
      allow delete: if isAdmin();
    }

    match /export_orders/{docId} {
      allow read: if hasAnyPerm(['export.view', 'export_requests.release', 'export_requests.process']);
      allow create: if hasAnyPerm(['export.create', 'export_requests.release', 'export_requests.process'])
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if isAdmin()
        || (
          hasAnyPerm(['export.edit'])
          && manualExportOrderData(resource.data)
          && manualExportOrderData(request.resource.data)
          && warehouseDocIdentitySafe()
          && unchanged([
            'source_request_id',
            'sync_source',
            'deleted',
            'active',
            'status',
            'deleted_at',
            'deleted_by',
            'deleted_reason',
            'cancelled_at',
            'cancelled_by',
            'cancel_reason'
          ])
        )
        || (
          hasAnyPerm(['export.delete'])
          && manualExportOrderData(resource.data)
          && manualExportOrderData(request.resource.data)
          && warehouseDocIdentitySafe()
          && unchanged(['source_request_id', 'sync_source'])
          && warehouseSoftDeleteOnly()
        );
      allow delete: if isAdmin();
    }

    match /export_order_items/{docId} {
      allow read: if hasAnyPerm(['export.view', 'export_requests.release', 'export_requests.process']);
      allow create: if request.resource.data.export_order_id is string
        && (
          hasAnyPerm(['export.create', 'export_requests.release', 'export_requests.process'])
          || (
            hasAnyPerm(['export.edit'])
            && manualExportOrderById(request.resource.data.export_order_id)
          )
        )
        && quantityIsNumber(request.resource.data)
        && request.resource.data.get('quantity', 0) > 0
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if isAdmin()
        || (
          hasAnyPerm(['export.edit'])
          && resource.data.export_order_id is string
          && manualExportOrderById(resource.data.export_order_id)
          && unchanged(['export_order_id', 'created_at', 'created_by', 'source'])
          && quantityIsNumber(request.resource.data)
          && request.resource.data.get('quantity', 0) > 0
        )
        || (
          hasAnyPerm(['export.delete'])
          && resource.data.export_order_id is string
          && manualExportOrderById(resource.data.export_order_id)
          && unchanged(['export_order_id', 'created_at', 'created_by', 'source'])
          && warehouseSoftDeleteOnly()
        );
      allow delete: if isAdmin();
    }

    match /inventory_adjustments/{docId} {
      allow read: if hasAnyPerm(['inventory.view', 'inventory.adjust']);
      allow create: if hasAnyPerm(['inventory.adjust'])
        && quantityIsNumber(request.resource.data)
        && request.resource.data.get('quantity', 0) != 0
        && ownEmailField(request.resource.data, 'created_by');
      // Điều chỉnh tồn là chứng từ append-only. Nếu nhập sai, tạo một
      // điều chỉnh ngược mới thay vì sửa/xóa lịch sử cũ.
      allow update, delete: if isAdmin();
    }


    match /warehouse_operations/{docId} {
      allow read: if canReadInventoryCore();
      allow create: if canWriteInventoryCore()
        && request.resource.data.get('operation_id', '') == docId
        && request.resource.data.get('status', '') == 'processing'
        && ownEmailField(request.resource.data, 'created_by');
      allow update: if resource.data.get('operation_id', '') == docId
        && request.resource.data.get('operation_id', '') == docId
        && resource.data.get('created_by', '').lower() == email()
        && unchanged([
          'operation_id',
          'action',
          'target_collection',
          'target_id',
          'created_by',
          'created_at',
          'source'
        ])
        && onlyChanged([
          'status',
          'processing_at',
          'completed_at',
          'failed_at',
          'failure_message',
          'result_code',
          'target_revision'
        ])
        && (
          (
            resource.data.get('status', '') == 'processing'
            && ['completed', 'failed'].hasAny([request.resource.data.get('status', '')])
          )
          || (
            ['failed', 'pending'].hasAny([resource.data.get('status', '')])
            && request.resource.data.get('status', '') == 'processing'
          )
        );
      allow delete: if false;
    }

    match /stock_movements/{docId} {
      allow read: if canReadInventoryCore();
      allow create: if canWriteInventoryCore()
        && request.resource.data.get('operation_id', '') != ''
        && quantityIsNumber(request.resource.data)
        && request.resource.data.get('quantity', 0) != 0
        && ownEmailField(request.resource.data, 'created_by');

      // Stock movements are append-only from the client. Corrections should
      // be represented as another adjustment movement, not by rewriting history.
      allow update, delete: if isAdmin();
    }

    match /inventory_balances/{docId} {
      allow read: if canReadInventoryCore();
      allow create, update: if canWriteInventoryCore()
        && request.resource.data.get('last_operation_id', '') != ''
        && ownEmailField(request.resource.data, 'updated_by')
        && balanceQuantityIsSafe();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------------
    // Logs, notifications and cached summaries
    // ---------------------------------------------------------------------

    match /warehouse_export_logs/{docId} {
      // Preserve the previous read behavior for active internal users.
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    match /activity_logs/{docId} {
      allow read: if hasPerm('activity_logs.view');

      // Rules can guarantee the authenticated actor email. A fully tamper-
      // proof audit trail still requires a trusted backend trigger.
      allow create: if signedIn()
        && ownEmailField(request.resource.data, 'changed_by');

      allow update, delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if isAdmin()
        || (
          activeUser()
          && (
            ownEmailField(resource.data, 'to_email')
            || notificationAudienceMatches(resource.data)
          )
        );

      allow create: if activeUser()
        && ownEmailField(request.resource.data, 'created_by')
        && notificationCreateTargetIsValid();

      // Direct recipients may still update legacy read fields. Broadcast
      // notifications use notification_reads so each warehouse user has an
      // independent read state.
      allow update: if isAdmin()
        || (
          activeUser()
          && ownEmailField(resource.data, 'to_email')
          && unchanged(['to_email', 'audience', 'audience_permissions', 'created_by', 'created_at'])
          && onlyChanged([
            'read',
            'is_read',
            'read_at',
            'seen',
            'seen_at',
            'status',
            'updated_at'
          ])
        );

      allow delete: if isAdmin();
    }

    match /notification_reads/{docId} {
      allow read: if activeUser()
        && ownEmailField(resource.data, 'user_email');

      allow create: if activeUser()
        && ownEmailField(request.resource.data, 'user_email')
        && request.resource.data.get('notification_id', '') is string
        && request.resource.data.get('notification_id', '') != '';

      allow update: if activeUser()
        && ownEmailField(resource.data, 'user_email')
        && ownEmailField(request.resource.data, 'user_email')
        && unchanged(['notification_id', 'user_email'])
        && onlyChanged(['read_at', 'created_at', 'updated_at', 'active', 'deleted']);

      allow delete: if isAdmin();
    }

    match /dashboard_summaries/{docId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    match /daily_summaries/{docId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    match /cache_manifest/{docId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }

    match /app_meta/{docId} {
      allow read: if activeUser();
      allow create, update, delete: if isAdmin();
    }
  }
}
