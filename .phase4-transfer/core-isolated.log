              <tbody>
                <tr v-for="(line, index) in selectedDetailOrderLines" :key="`${line.product_code}|${line.logo}|${index}`">
                  <td><b>{{ line.product_name }}</b><div class="small subtle">{{ line.product_code }}</div></td>
                  <td>{{ line.logo || '-' }}</td>
                  <td>{{ line.logo_color || '-' }}</td>
                  <td>{{ line.unit || '-' }}</td>
