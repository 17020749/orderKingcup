                  <th>Mã / Ngày</th><th>Khách / SĐT</th><th>Phân loại</th><th>Trạng thái</th><th>Thanh toán</th><th>Hóa đơn</th>
                  <th>Tạm tính</th><th>VAT</th><th>Tổng tiền</th><th>Đã thu</th><th>Công nợ</th><th>Xuất kho</th><th>Thao tác</th>
                </tr>
              </thead>
              <tbody>
